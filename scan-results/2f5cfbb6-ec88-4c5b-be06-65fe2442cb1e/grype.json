ation file. In both \ncases, the attack requires existing privilege.","cvss":[{"source":"vulnerability@ncsc.ch","type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:L/AC:L/AT:P/PR:H/UI:P/VC:H/VI:L/VA:L/SC:H/SI:L/SA:L/E:X/CR:X/IR:X/AR:X/MAV:X/MAC:X/MAT:X/MPR:X/MUI:X/MVC:X/MVI:X/MVA:X/MSC:X/MSI:X/MSA:X/S:X/AU:N/R:X/V:X/RE:M/U:Green","metrics":{"baseScore":5.9},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2025-11226","epss":0.00058,"percentile":0.17983,"date":"2026-04-16"}],"cwes":[{"cve":"CVE-2025-11226","cwe":"CWE-20","source":"vulnerability@ncsc.ch","type":"Secondary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"java-matcher","searchedBy":{"language":"java","namespace":"github:language:java","package":{"name":"ch.qos.logback:logback-core","version":"1.5.13"}},"found":{"vulnerabilityID":"GHSA-25qh-j22f-pwp8","versionConstraint":">=1.4.0,<1.5.19 (unknown)"},"fix":{"suggestedVersion":"1.5.19"}}],"artifact":{"id":"af3805257d033137","name":"logback-core","version":"1.5.13","type":"java-archive","locations":[{"path":"/Backend/pom.xml","accessPath":"/Backend/pom.xml","annotations":{"evidence":"primary"}}],"language":"java","licenses":[],"cpes":["cpe:2.3:a:logback-core:logback-core:1.5.13:*:*:*:*:*:*:*","cpe:2.3:a:logback-core:logback_core:1.5.13:*:*:*:*:*:*:*","cpe:2.3:a:logback_core:logback-core:1.5.13:*:*:*:*:*:*:*","cpe:2.3:a:logback_core:logback_core:1.5.13:*:*:*:*:*:*:*","cpe:2.3:a:logback:logback-core:1.5.13:*:*:*:*:*:*:*","cpe:2.3:a:logback:logback_core:1.5.13:*:*:*:*:*:*:*"],"purl":"pkg:maven/ch.qos.logback/logback-core@1.5.13","upstreams":[],"metadataType":"JavaMetadata","metadata":{"virtualPath":"","pomArtifactID":"logback-core","pomGroupID":"ch.qos.logback","manifestName":"","archiveDigests":null}}},{"vulnerability":{"id":"GHSA-3p68-rc4w-qgx5","dataSource":"https://github.com/advisories/GHSA-3p68-rc4w-qgx5","namespace":"github:language:javascript","severity":"Medium","urls":["https://github.com/axios/axios/security/advisories/GHSA-3p68-rc4w-qgx5"